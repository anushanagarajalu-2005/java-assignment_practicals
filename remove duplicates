class Solution {
    public int removeDuplicates(int[] nums) {
        int k = 1;  // index for placing next unique element

        for (int i = 1; i < nums.length; i++) {
            if (nums[i] != nums[i - 1]) {
                nums[k] = nums[i];
                k++;
            }
        }

        return k;
    }
}
